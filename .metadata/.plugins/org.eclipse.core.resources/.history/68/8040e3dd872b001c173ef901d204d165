package br.com.mv.breakfast.repository;




import java.util.Optional;

import javax.transaction.Transactional;

import org.springframework.data.jpa.repository.JpaRepository;
import org.springframework.stereotype.Repository;

import br.com.mv.breakfast.domain.Colaborador;









@Repository
public interface ColaboradorRepository extends JpaRepository<Colaborador,String> {
	

	

	public Optional<Colaborador> findByNome(String nome);
	@Transactional
	public Optional<Colaborador> deleteByNome(String nome);
}
